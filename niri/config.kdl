// --- МОНИТОРЫ ---
// Твой DP-1 на 144Гц слева от HDMI
output "DP-1" {
    mode "1920x1080@144.00"
    position x=-1920 y=0
}

output "HDMI-A-1" {
    mode "1920x1080@60.00"
    position x=0 y=0
}

// --- ВВОД (Клавиатура) ---
input {
    keyboard {
        xkb {
            layout "us,ru"
            options "grp:alt_shift_toggle,grp_led:scroll"
        }
    }
    touchpad {
        tap
    }
    mouse {
        // Примерная адаптация твоей чувствительности -0.7
        accel-speed -0.7
    }
}

// --- ЛАЙАУТ И ДЕКОРАЦИИ ---
layout {
    gaps 12
    center-focused-column "never"
    
    default-column-width { proportion 0.5; }

    preset-column-widths {
        proportion 0.333
        proportion 0.5
        proportion 0.666
    }

    focus-ring {
        width 2
        // Твой градиент из Hyprland (приближенно)
        active-color "#FFF9E0aa"
        inactive-color "#ffffff00"
    }

    // Твои скругления 18px
    geometry-corner-radius 18
}

// --- АВТОЗАПУСК ---
spawn-at-startup "waybar"
spawn-at-startup "swww-daemon"
spawn-at-startup "~/.config/bin/live-wallpaper.sh"
spawn-at-startup "mako"
spawn-at-startup "ydotoold"
spawn-at-startup "sslocal" "-b" "127.0.0.1:1080" "--server-url" "ss://Y2hhY2hhMjAtaWV0Zi1wb2x5MTMwNTprNlM5bG56VE45YTA2OUN1SDBFZks5@46.32.186.62:64809/"
spawn-at-startup "/usr/lib/hyprpolkitagent/hyprpolkitagent"
spawn-at-startup "hypridle"
spawn-at-startup "clipse" "-listen"
spawn-at-startup "gnome-keyring-daemon" "--start" "--components=secrets"
spawn-at-startup "hyprsunset"

// --- ПЕРЕМЕННЫЕ ОКРУЖЕНИЯ (лучше в .zshrc, но можно и здесь) ---
environment {
    "QT_QPA_PLATFORMTHEME" "qt6ct"
    "LIBVA_DRIVER_NAME" "nvidia"
    "__GLX_VENDOR_LIBRARY_NAME" "nvidia"
}

// --- БИНДЫ ---
binds {
    // Терминал и программы
    Mod+Return { spawn "kitty"; }
    Mod+Z { spawn "kitty"; }
    Mod+B { spawn "zen-browser"; }
    Mod+E { spawn "nautilus"; }
    Mod+X { spawn "wofi" "--show" "drun"; }
    Mod+T { spawn "telegram-desktop"; }
    
    // Управление окнами
    Mod+C { close-window; }
    Mod+F { toggle-window-floating; }
    Mod+Alt+F { maximize-column; }
    Mod+Alt+Space { toggle-fullscreen-view; }
    
    // Навигация (Focus)
    Mod+Left  { focus-column-left; }
    Mod+Right { focus-column-right; }
    Mod+Up    { focus-window-up; }
    Mod+Down  { focus-window-down; }
    
    // Перемещение окон
    Mod+Alt+Left  { move-column-left; }
    Mod+Alt+Right { move-column-right; }
    
    // Ресайз (как в твоем конфиге)
    Mod+Shift+Left  { set-column-width "-10%"; }
    Mod+Shift+Right { set-column-width "+10%"; }
    
    // Воркспейсы (в niri это переключение между колонками/лентами)
    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    
    Mod+Ctrl+1 { move-column-to-workspace 1; }
    Mod+Ctrl+2 { move-column-to-workspace 2; }
    
    // Спец-бинды
    Mod+V { spawn "kitty" "--class" "clipse" "clipse"; }
    Print { spawn "grimblast" "edit" "area"; }
    Mod+L { spawn "hyprlock"; }
    
    // Мультимедиа
    XF86AudioRaiseVolume { spawn "pactl" "set-sink-volume" "@DEFAULT_SINK@" "+5%"; }
    XF86AudioLowerVolume { spawn "pactl" "set-sink-volume" "@DEFAULT_SINK@" "-5%"; }
    XF86AudioMute        { spawn "pactl" "set-sink-mute" "@DEFAULT_SINK@" "toggle"; }
}

// --- ПРАВИЛА ОКОН ---
window-rule {
    match app-id="org.telegram.desktop"
    default-column-width { proportion 0.3; }
}

window-rule {
    match app-id="clipse"
    open-floating true
    default-floating-width 600
    default-floating-height 400
}

window-rule {
    match app-id="nautilus"
    opacity 0.9
}
