// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "language_models": {
    "openai_compatible": {
      "Groq": {
        "api_url": "https://api.groq.com/openai/v1",
        "available_models": [
          {
            "name": "meta-llama/llama-4-scout-17b-16e-instruct",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
              "interleaved_reasoning": false,
            },
          },
        ],
      },
    },
  },
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "ui_font_family": "New York Small",
  "proxy": "http://127.0.0.1:2080",
  "scrollbar": {
    "show": "auto",
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },
  "show_whitespaces": "boundary",
  "agent_buffer_font_size": 14.0,
  "agent_ui_font_size": 18.0,
  "buffer_line_height": "comfortable",
  "buffer_font_weight": 400.0,
  "inline_code_actions": false,
  "indent_guides": {
    "coloring": "fixed",
    "background_coloring": "disabled",
  },
  "lsp_document_colors": "background",
  "use_system_prompts": true,
  "use_system_path_prompts": true,
  "git_panel": {
    "dock": "left",
    "tree_view": true,
  },
  "agent_servers": {
    "gemini": {
      "type": "registry",
    },
  },
  "vim_mode": false,
  "buffer_font_family": ".ZedMono",
  "context_servers": {
    "b24-dev-mcp": {
      "enabled": true,
      "url": "https://mcp-dev.bitrix24.tech/mcp",
    },
    "mcp-server-context7": {
      "enabled": true,
      "settings": {
        "context7_api_key": "ctx7sk-0636e754-612a-45c2-87cc-35ba61ac1657",
      },
    },
  },
  "icon_theme": "Catppuccin Frappé",
  "terminal": {
    "toolbar": {
      "breadcrumbs": false
    },
    "scrollbar": {
      "show": "auto",
    },
    "dock": "bottom",
  },
  "agent": {
    "sidebar_side": "right",
    "tool_permissions": {
      "default": "confirm",
      "tools": {
        "edit_file": {
          "default": "confirm"
        }
      }
    },
    "flexible": true,
    "dock": "right",
    "favorite_models": [
      {
        "provider": "google",
        "model": "gemini-2.5-flash",
        "enable_thinking": false
      },
      {
        "provider": "google",
        "model": "gemini-2.5-flash-lite",
        "enable_thinking": false
      },
      {
        "provider": "google",
        "model": "gemini-3-flash-preview",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "google/gemma-4-31b-it:free",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "google/gemma-4-26b-a4b-it:free",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "deepseek/deepseek-v3.2",
        "enable_thinking": true
      },
      {
        "provider": "openrouter",
        "model": "qwen/qwen3-coder-next",
        "enable_thinking": false
      }
    ],
    "play_sound_when_agent_done": "always",
    "profiles": {
      "ask": {
        "name": "Ask",
        "tools": {
          "search_web": true,
          "diagnostics": true,
          "fetch": true,
          "list_directory": true,
          "project_notifications": false,
          "now": true,
          "find_path": true,
          "read_file": true,
          "open": true,
          "grep": true,
          "thinking": true,
        },
        "enable_all_context_servers": false,
        "context_servers": {
          "b24-dev-mcp": {
            "tools": {
              "bitrix-app-development-doc-details": true,
              "bitrix-article-details": true,
              "bitrix-event-details": true,
              "bitrix-method-details": true,
              "bitrix-search": true
            }
          },
          "mcp-server-context7": {
            "tools": {
              "query-docs": true,
              "resolve-library-id": true,
              "get-library-docs": true,
            },
          },
        },
      },
      "write": {
        "name": "Write",
        "tools": {
          "search_web": true,
          "copy_path": true,
          "create_directory": true,
          "delete_path": true,
          "diagnostics": true,
          "edit_file": true,
          "fetch": true,
          "list_directory": true,
          "project_notifications": false,
          "move_path": true,
          "now": true,
          "find_path": true,
          "read_file": true,
          "open": true,
          "grep": true,
          "terminal": true,
          "thinking": true,
        },
        "enable_all_context_servers": true,
        "context_servers": {
          "mcp-server-context7": {
            "tools": {
              "resolve-library-id": true,
              "get-library-docs": true,
            },
          },
        },
      },
    },
    "default_model": {
      "enable_thinking": true,
      "provider": "openrouter",
      "model": "deepseek/deepseek-v3.2",
    },
    "default_profile": "ask",
  },
  "ui_font_size": 16.0,
  "buffer_font_size": 14.0,
  "theme": "Catppuccin Frappé (Blur) [Light]",
  "experimental.theme_overrides": {
    "scrollbar.thumb.background": "#4f5e72",
    "title_bar.background": "#1a1d23b2",
    "title_bar.inactive_background": "#1a1d23b2",
    "status_bar.background": "#1a1d23b2",
    "background": "#1a1d23b2",
    // "background": "#1a1d2380",
    // "background": "#232136b2",
    "syntax": {
      "type": {
        "color": "#8cb6ff",
      },
    },
  },
  "base_keymap": "JetBrains",
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "languages": {
    // "LaTeX": {
    //   "colorize_brackets": false,
    //   "indent_guides": {
    //     "active_line_width": 1,
    //     "background_coloring": "disabled",
    //   },
    // },
    "C++": {
      "format_on_save": "off",
    },
    "Python": {
      "indent_guides": {
        "background_coloring": "disabled",
        "active_line_width": 1,
        "line_width": 1,
        "enabled": true,
        "coloring": "indent_aware",
      },
    },
    "PHP": {
      "format_on_save": "off",
      "language_servers": ["!phpactor", "intelephense", "!phptools"],
      "prettier": {
        "allowed": true,
        "plugins": ["@prettier/plugin-php"],
        "parser": "php",
      },
    },
  },
  "format_on_save": "on",
  "snippet_sort_order": "top",
  "lsp": {
    "texlab": {
      "settings": {
        "texlab": {
          "build": {
            "onSave": true,
            "forwardSearchAfter": true,
          },
        },
      },
    },
